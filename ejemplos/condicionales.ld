// Ejemplo 3: Estructura condicional (Si/Sino)

var edad = 18;

si (edad >= 18) {
    escribir("Eres mayor de edad");
} sino {
    escribir("Eres menor de edad");
}

var numero = 15;

si (numero > 10) {
    escribir("El número es mayor a 10");
}

si (numero < 5) {
    escribir("El número es menor a 5");
} sino {
    escribir("El número es igual o mayor a 5");
}
