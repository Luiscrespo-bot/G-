// Ejemplo 9: Concatenación de textos

var nombre = "Juan";
var apellido = "Pérez";
var nombre_completo = nombre + " " + apellido;

escribir(nombre_completo);

var mensaje = "Hola " + nombre;
escribir(mensaje);

// Mezcla de números y textos
var edad = 25;
var presentacion = nombre + " tiene " + edad + " años";
escribir(presentacion);
