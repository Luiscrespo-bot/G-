// Ejemplo 4: Bucles (mientras)

escribir("Contando hasta 5:");
var contador = 1;

mientras (contador <= 5) {
    escribir(contador);
    contador = contador + 1;
}

escribir("Fin del conteo");

// Otro ejemplo
var suma = 0;
var i = 1;

mientras (i <= 10) {
    suma = suma + i;
    i = i + 1;
}

escribir("La suma de 1 a 10 es:", suma);
